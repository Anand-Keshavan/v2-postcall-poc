{
  "name": "postcall-poc",
  "version": "0.1.0",
  "description": "PostCall Universal API Platform POC - validation gate and demo",
  "private": true,
  "scripts": {
    "validate": "node gate/validate-oas-plus.js",
    "validate:sample": "node gate/validate-oas-plus.js specs/sample-oas-plus.yaml",
    "mock": "node proxy/mock-backend.js",
    "proxy": "node proxy/universal-proxy.js",
    "proxy:postcall": "node proxy/postcall-proxy.js",
    "demo": "node proxy/run-demo.js",
    "demo:phase3": "node proxy/run-demo-phase3.js",
    "demo:phase4": "node proxy/run-demo-phase4.js",
    "build-index": "node scripts/build-rag-index.js",
    "build-doc-index": "node scripts/build-doc-aware-index.js",
    "build-indexes": "node scripts/build-doc-aware-index.js && node scripts/build-graphql-index.js",
    "agent": "node agent/postcall-agent-v2.js",
    "start": "node agent/postcall-agent-v2.js"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-graphql": "^0.12.0",
    "express-session": "^1.17.3",
    "graphql": "^16.13.1",
    "yaml": "^2.3.4"
  }
}
